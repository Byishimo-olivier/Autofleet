# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=autofleet_secret_key_2024_change_in_production

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
